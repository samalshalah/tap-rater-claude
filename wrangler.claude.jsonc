{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tap-rater-app-claude",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-09",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "NEXT_PUBLIC_SITE_URL": "https://tap-rater-app-claude.sam-alshalah1.workers.dev"
  }
}
